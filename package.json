{
  "name": "dsc_bot",
  "module": "./src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "debug": "bun --watch src/index.ts --debug",
    "build": "bun build $(find src -name '*.ts') --outdir dist --minify --target bun",
    "lint": "bunx eslint src --ext .ts,.js --fix || watch -n 0.5 bunx eslint src --ext .ts,.js",
    "lint:fix": "bunx eslint src --ext .ts,.js --fix",
    "type-check": "bunx tsc --noEmit",
    "prepare": "husky"
  },
  "private": true,
  "lint-staged": {
    "*": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^24.7.2",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "prisma": "^6.17.1",
    "typescript-eslint": "^8.46.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@discordjs/builders": "^1.12.2",
    "@prisma/client": "^6.17.1",
    "chalk": "^5.6.2",
    "discord.js": "^15.0.0-dev.1760227315-180dd60c6",
    "dotenv": "^17.2.3",
    "mariadb": "^3.4.5",
    "module-alias": "^2.2.3"
  }
}
